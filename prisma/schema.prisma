// ============================================================
// Prisma Schema — RF Electro Tech ERP System
// Full schema: Auth, Inventory, Purchasing, Sales,
//              Customers, Finance, HR, Reports
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  admin
  manager
  employee
  @@map("user_role")
}

enum OrderStatus {
  draft
  confirmed
  processing
  shipped
  delivered
  cancelled
  returned
  @@map("order_status")
}

enum PaymentStatus {
  pending
  partial
  paid
  overdue
  refunded
  @@map("payment_status")
}

enum PaymentMethod {
  cash
  bank_transfer
  cheque
  credit_card
  online
  @@map("payment_method")
}

enum PurchaseOrderStatus {
  draft
  sent
  partial
  received
  cancelled
  @@map("purchase_order_status")
}

enum StockMovementType {
  purchase
  sale
  adjustment
  transfer
  return_in
  return_out
  @@map("stock_movement_type")
}

enum LeaveStatus {
  pending
  approved
  rejected
  cancelled
  @@map("leave_status")
}

enum AttendanceStatus {
  present
  absent
  late
  half_day
  @@map("attendance_status")
}

enum InvoiceType {
  sale
  purchase
  @@map("invoice_type")
}

enum ServiceJobStatus {
  received
  diagnosing
  waiting_parts
  in_repair
  ready
  delivered
  cancelled
  @@map("service_job_status")
}

// ─────────────────────────────────────────────────────────────
// MODULE 1 — AUTH & USER MANAGEMENT
// ─────────────────────────────────────────────────────────────

model Profile {
  id          String   @id @db.Uuid
  email       String   @unique
  fullName    String   @map("full_name")
  role        UserRole @default(employee)
  employeeId  String?  @unique @map("employee_id")
  department  String?
  phone       String?
  avatarUrl   String?  @map("avatar_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  auditLogsAsActor   UserAuditLog[]     @relation("AuditActor")
  auditLogsAsTarget  UserAuditLog[]     @relation("AuditTarget")
  salesOrders        SalesOrder[]
  purchaseOrders     PurchaseOrder[]
  employee           Employee?
  createdProducts    Product[]          @relation("ProductCreatedBy")
  stockAdjustments   StockMovement[]    @relation("StockMovedBy")
  serviceJobs        ServiceJob[]       @relation("ServiceAssignedTo")

  @@map("profiles")
}

model RolePermission {
  id         Int      @id @default(autoincrement())
  role       UserRole
  permission String
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([role, permission])
  @@map("role_permissions")
}

model UserAuditLog {
  id        Int      @id @default(autoincrement())
  actorId   String?  @map("actor_id") @db.Uuid
  targetId  String?  @map("target_id") @db.Uuid
  action    String
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  actor  Profile? @relation("AuditActor",  fields: [actorId],  references: [id])
  target Profile? @relation("AuditTarget", fields: [targetId], references: [id])

  @@map("user_audit_log")
}

// ─────────────────────────────────────────────────────────────
// MODULE 2 — PRODUCTS & INVENTORY
// ─────────────────────────────────────────────────────────────

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  parentId    Int?      @map("parent_id")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@map("categories")
}

model Unit {
  id        Int       @id @default(autoincrement())
  name      String    @unique   // e.g. "Piece", "Box", "Meter"
  symbol    String    @unique   // e.g. "pcs", "box", "m"
  products  Product[]

  @@map("units")
}

model Product {
  id              Int      @id @default(autoincrement())
  sku             String   @unique
  name            String
  description     String?
  categoryId      Int?     @map("category_id")
  unitId          Int?     @map("unit_id")
  costPrice       Decimal  @default(0) @map("cost_price") @db.Decimal(12, 2)
  sellingPrice    Decimal  @default(0) @map("selling_price") @db.Decimal(12, 2)
  reorderLevel    Int      @default(0) @map("reorder_level")
  isActive        Boolean  @default(true) @map("is_active")
  isSerialized    Boolean  @default(false) @map("is_serialized") // track by serial number
  imageUrl        String?  @map("image_url")
  createdById     String?  @map("created_by_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  category         Category?          @relation(fields: [categoryId], references: [id])
  unit             Unit?              @relation(fields: [unitId], references: [id])
  createdBy        Profile?           @relation("ProductCreatedBy", fields: [createdById], references: [id])
  stockItems       StockItem[]
  stockMovements   StockMovement[]
  purchaseOrderLines PurchaseOrderLine[]
  salesOrderLines  SalesOrderLine[]
  serviceJobParts  ServiceJobPart[]

  @@map("products")
}

model Warehouse {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  location    String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  stockItems  StockItem[]
  stockMovementsFrom StockMovement[] @relation("MovementFrom")
  stockMovementsTo   StockMovement[] @relation("MovementTo")

  @@map("warehouses")
}

model StockItem {
  id            Int       @id @default(autoincrement())
  productId     Int       @map("product_id")
  warehouseId   Int       @map("warehouse_id")
  quantity      Decimal   @default(0) @db.Decimal(12, 2)
  reservedQty   Decimal   @default(0) @map("reserved_qty") @db.Decimal(12, 2)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@map("stock_items")
}

model StockMovement {
  id            Int               @id @default(autoincrement())
  productId     Int               @map("product_id")
  type          StockMovementType
  quantity      Decimal           @db.Decimal(12, 2)
  fromWarehouseId Int?            @map("from_warehouse_id")
  toWarehouseId   Int?            @map("to_warehouse_id")
  referenceId   Int?              @map("reference_id")   // order/PO id
  referenceType String?           @map("reference_type") // "sale_order","purchase_order"
  notes         String?
  movedById     String?           @map("moved_by_id") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  product       Product    @relation(fields: [productId], references: [id])
  fromWarehouse Warehouse? @relation("MovementFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse? @relation("MovementTo",   fields: [toWarehouseId],   references: [id])
  movedBy       Profile?   @relation("StockMovedBy", fields: [movedById],       references: [id])

  @@map("stock_movements")
}

// ─────────────────────────────────────────────────────────────
// MODULE 3 — SUPPLIERS & PURCHASING
// ─────────────────────────────────────────────────────────────

model Supplier {
  id            Int       @id @default(autoincrement())
  name          String
  contactPerson String?   @map("contact_person")
  email         String?
  phone         String?
  address       String?
  taxNumber     String?   @map("tax_number")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

model PurchaseOrder {
  id            Int                 @id @default(autoincrement())
  poNumber      String              @unique @map("po_number")
  supplierId    Int                 @map("supplier_id")
  status        PurchaseOrderStatus @default(draft)
  orderDate     DateTime            @map("order_date") @db.Date
  expectedDate  DateTime?           @map("expected_date") @db.Date
  subtotal      Decimal             @default(0) @db.Decimal(12, 2)
  taxAmount     Decimal             @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount   Decimal             @default(0) @map("total_amount") @db.Decimal(12, 2)
  notes         String?
  createdById   String?             @map("created_by_id") @db.Uuid
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  supplier    Supplier           @relation(fields: [supplierId], references: [id])
  createdBy   Profile?           @relation(fields: [createdById], references: [id])
  lines       PurchaseOrderLine[]
  payments    Payment[]

  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id              Int      @id @default(autoincrement())
  purchaseOrderId Int      @map("purchase_order_id")
  productId       Int      @map("product_id")
  quantity        Decimal  @db.Decimal(12, 2)
  receivedQty     Decimal  @default(0) @map("received_qty") @db.Decimal(12, 2)
  unitCost        Decimal  @map("unit_cost") @db.Decimal(12, 2)
  totalCost       Decimal  @map("total_cost") @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("purchase_order_lines")
}

// ─────────────────────────────────────────────────────────────
// MODULE 4 — CUSTOMERS & CRM
// ─────────────────────────────────────────────────────────────

model Customer {
  id            Int       @id @default(autoincrement())
  name          String
  contactPerson String?   @map("contact_person")
  email         String?
  phone         String?
  address       String?
  taxNumber     String?   @map("tax_number")
  creditLimit   Decimal   @default(0) @map("credit_limit") @db.Decimal(12, 2)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  salesOrders  SalesOrder[]
  serviceJobs  ServiceJob[]

  @@map("customers")
}

// ─────────────────────────────────────────────────────────────
// MODULE 5 — SALES & ORDERS
// ─────────────────────────────────────────────────────────────

model SalesOrder {
  id            Int           @id @default(autoincrement())
  orderNumber   String        @unique @map("order_number")
  customerId    Int           @map("customer_id")
  status        OrderStatus   @default(draft)
  paymentStatus PaymentStatus @default(pending) @map("payment_status")
  orderDate     DateTime      @map("order_date") @db.Date
  dueDate       DateTime?     @map("due_date") @db.Date
  subtotal      Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount Decimal      @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  totalAmount   Decimal       @default(0) @map("total_amount") @db.Decimal(12, 2)
  paidAmount    Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  notes         String?
  createdById   String?       @map("created_by_id") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  customer  Customer         @relation(fields: [customerId], references: [id])
  createdBy Profile?         @relation(fields: [createdById], references: [id])
  lines     SalesOrderLine[]
  payments  Payment[]

  @@map("sales_orders")
}

model SalesOrderLine {
  id           Int     @id @default(autoincrement())
  salesOrderId Int     @map("sales_order_id")
  productId    Int     @map("product_id")
  quantity     Decimal @db.Decimal(12, 2)
  unitPrice    Decimal @map("unit_price") @db.Decimal(12, 2)
  discount     Decimal @default(0) @db.Decimal(5, 2)  // percentage
  totalPrice   Decimal @map("total_price") @db.Decimal(12, 2)

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@map("sales_order_lines")
}

// ─────────────────────────────────────────────────────────────
// MODULE 6 — FINANCE & PAYMENTS
// ─────────────────────────────────────────────────────────────

model Payment {
  id              Int           @id @default(autoincrement())
  referenceType   String        @map("reference_type") // "sales_order" | "purchase_order"
  salesOrderId    Int?          @map("sales_order_id")
  purchaseOrderId Int?          @map("purchase_order_id")
  amount          Decimal       @db.Decimal(12, 2)
  method          PaymentMethod
  paidAt          DateTime      @map("paid_at") @db.Timestamptz()
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  salesOrder    SalesOrder?    @relation(fields: [salesOrderId],    references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@map("payments")
}

model Expense {
  id          Int       @id @default(autoincrement())
  title       String
  amount      Decimal   @db.Decimal(12, 2)
  category    String
  method      PaymentMethod
  expenseDate DateTime  @map("expense_date") @db.Date
  notes       String?
  receiptUrl  String?   @map("receipt_url")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@map("expenses")
}

// ─────────────────────────────────────────────────────────────
// MODULE 7 — SERVICE & REPAIR JOBS
// ─────────────────────────────────────────────────────────────

model ServiceJob {
  id              Int              @id @default(autoincrement())
  jobNumber       String           @unique @map("job_number")
  customerId      Int              @map("customer_id")
  assignedToId    String?          @map("assigned_to_id") @db.Uuid
  status          ServiceJobStatus @default(received)
  deviceName      String           @map("device_name")
  deviceModel     String?          @map("device_model")
  serialNumber    String?          @map("serial_number")
  problemDesc     String           @map("problem_desc")
  diagnosisNotes  String?          @map("diagnosis_notes")
  estimatedCost   Decimal?         @map("estimated_cost") @db.Decimal(12, 2)
  finalCost       Decimal?         @map("final_cost") @db.Decimal(12, 2)
  warrantyPeriod  Int?             @map("warranty_period") // days
  receivedAt      DateTime         @default(now()) @map("received_at") @db.Timestamptz()
  completedAt     DateTime?        @map("completed_at") @db.Timestamptz()
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  customer    Customer          @relation(fields: [customerId],   references: [id])
  assignedTo  Profile?          @relation("ServiceAssignedTo", fields: [assignedToId], references: [id])
  parts       ServiceJobPart[]

  @@map("service_jobs")
}

model ServiceJobPart {
  id           Int     @id @default(autoincrement())
  serviceJobId Int     @map("service_job_id")
  productId    Int     @map("product_id")
  quantity     Decimal @db.Decimal(12, 2)
  unitCost     Decimal @map("unit_cost") @db.Decimal(12, 2)

  serviceJob ServiceJob @relation(fields: [serviceJobId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId],    references: [id])

  @@map("service_job_parts")
}

// ─────────────────────────────────────────────────────────────
// MODULE 8 — HR & PAYROLL
// ─────────────────────────────────────────────────────────────

model Employee {
  id             Int       @id @default(autoincrement())
  profileId      String    @unique @map("profile_id") @db.Uuid
  designation    String
  department     String
  joinDate       DateTime  @map("join_date") @db.Date
  baseSalary     Decimal   @map("base_salary") @db.Decimal(12, 2)
  bankAccount    String?   @map("bank_account")
  nationalId     String?   @unique @map("national_id")
  emergencyContact String? @map("emergency_contact")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  profile     Profile      @relation(fields: [profileId], references: [id])
  attendance  Attendance[]
  leaves      Leave[]
  payrolls    Payroll[]

  @@map("employees")
}

model Attendance {
  id         Int              @id @default(autoincrement())
  employeeId Int              @map("employee_id")
  date       DateTime         @db.Date
  status     AttendanceStatus
  checkIn    DateTime?        @map("check_in") @db.Timestamptz()
  checkOut   DateTime?        @map("check_out") @db.Timestamptz()
  notes      String?
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@map("attendance")
}

model Leave {
  id          Int         @id @default(autoincrement())
  employeeId  Int         @map("employee_id")
  leaveType   String      @map("leave_type")  // "annual", "sick", "unpaid"
  startDate   DateTime    @map("start_date") @db.Date
  endDate     DateTime    @map("end_date") @db.Date
  days        Int
  status      LeaveStatus @default(pending)
  reason      String?
  approvedById String?    @map("approved_by_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("leaves")
}

model Payroll {
  id            Int       @id @default(autoincrement())
  employeeId    Int       @map("employee_id")
  month         Int       // 1-12
  year          Int
  baseSalary    Decimal   @map("base_salary") @db.Decimal(12, 2)
  allowances    Decimal   @default(0) @db.Decimal(12, 2)
  deductions    Decimal   @default(0) @db.Decimal(12, 2)
  netSalary     Decimal   @map("net_salary") @db.Decimal(12, 2)
  paidAt        DateTime? @map("paid_at") @db.Timestamptz()
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, month, year])
  @@map("payrolls")
}
